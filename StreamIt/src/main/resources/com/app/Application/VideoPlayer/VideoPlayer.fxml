<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0" stylesheets="@VideoPlayer.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.Application.VideoPlayer.VideoPlayerController">

    <ImageView fx:id="videoImageView" pickOnBounds="true" preserveRatio="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

    <AnchorPane fx:id="controlsPane" prefHeight="66.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <ImageView fx:id="PausePlayIcon" fitHeight="36.0" fitWidth="35.0" layoutX="14.0" layoutY="23.0" onMouseClicked="#onTogglePlayPause" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="-3.0" AnchorPane.leftAnchor="0.0" />

        <Button fx:id="stopButton" layoutX="1148.0" layoutY="25.0" onAction="#onStop" text="Stop" />

        <ProgressBar fx:id="progressBar" layoutX="14.0" layoutY="7.0" prefHeight="11.0" prefWidth="1280.0" progress="0.0" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

        <ImageView fx:id="FullScreenImage" fitHeight="36.0" fitWidth="42.0" layoutX="1218.0" layoutY="23.0" onMouseClicked="#toggleFullScreen" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="-2.0" AnchorPane.rightAnchor="1.0">
            <image>
                <Image url="@fullscreen.png" />
            </image>
        </ImageView>
      <Slider fx:id="VolumeBar" layoutX="114.0" layoutY="29.0" prefHeight="3.0" prefWidth="140.0" />
      <ImageView fx:id="VolumeImage" fitHeight="36.0" fitWidth="35.0" layoutX="69.0" layoutY="22.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@audio.png" />
         </image>
      </ImageView>
      <CheckBox fx:id="AdaptiveCheck" layoutX="293.0" layoutY="28.0" mnemonicParsing="false" text="Adaptive" />

    </AnchorPane>

    <AnchorPane fx:id="BackToChoicePane" layoutX="14.0" layoutY="19.0" prefHeight="45.0" prefWidth="50.0">
        <children>
            <ImageView fx:id="BackToChoiceScene" fitHeight="36.0" fitWidth="41.0" layoutX="5.0" layoutY="6.0" onMouseClicked="#switchToChoiceScene" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@left-chevron.png" />
                </image>
            </ImageView>
        </children>
    </AnchorPane>
   <ImageView fx:id="LoadingImage" fitHeight="148.0" fitWidth="153.0" layoutX="564.0" layoutY="286.0" pickOnBounds="true" preserveRatio="true" visible="false">
      <image>
         <Image url="@loading-load.gif" />
      </image>
   </ImageView>
</AnchorPane>
