        <ChoiceBox fx:id="AudioChoicebox" layoutX="341.0" layoutY="63.0" onAction="#onAudioSelected" prefHeight="23.0" prefWidth="558.0" />
        <Text layoutX="341.0" layoutY="49.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Audio Output Device :" />
        <Text layoutX="341.0" layoutY="142.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Recording's Path:" />
        <TextField fx:id="PathText" editable="false" layoutX="341.0" layoutY="154.0" prefHeight="29.0" prefWidth="411.0" />
        <Button fx:id="chooseButton" layoutX="759.0" layoutY="153.0" mnemonicParsing="false" onAction="#onChooseFolder" prefHeight="31.0" prefWidth="130.0" text="Choose Path" />
    </Pane>
    <VBox fx:id="MenuPane" layoutY="69.0" prefHeight="198.0" prefWidth="200.0" visible="false" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="72.0">
