        <Button maxWidth="Infinity" onAction="#ClickedOnLibrary" text="Library" VBox.vgrow="ALWAYS" />
        <Separator />
        <Button maxWidth="Infinity" onAction="#ClickedOnRecommended" text="Recommended" VBox.vgrow="ALWAYS" />
        <Separator />
        <Button maxWidth="Infinity" onAction="#ClickedOnMovies" text="Movies" VBox.vgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#ClickedOnShows" text="Shows" VBox.vgrow="ALWAYS" />
